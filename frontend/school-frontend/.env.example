# Frontend environment variables
# Set this to your auth service base URL (or API gateway base URL if proxied)
VITE_AUTH_API_URL=http://localhost:5001
# Stripe publishable key for client-side checkout UI
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY
# Stripe backend endpoint for creating payment intents (also handles messaging/notifications)
VITE_STRIPE_API_URL=http://localhost:5005
